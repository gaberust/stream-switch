# ── Required ──────────────────────────────────────────────────────────────────

# A long, random secret used to sign session cookies.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-char-string!!

# YouTube OAuth2 credentials — see README for setup instructions.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# The full URL of your server followed by /api/youtube/callback
# Must match exactly what you entered in Google Cloud Console.
# Example: http://192.168.1.100:3000/api/youtube/callback
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback

# ── Reverse proxy ─────────────────────────────────────────────────────────────
# Set to true if running behind nginx, Caddy, or another HTTPS reverse proxy.
# This enables secure session cookies and tells the app to trust X-Forwarded-* headers.
TRUST_PROXY=false

# Controls which host interface Docker binds port 3000 on.
# 0.0.0.0 = accessible from any network interface (default, works for both direct and proxy deployments)
# 127.0.0.1 = only accessible from localhost (use if you want to restrict access to the proxy host only)
BIND_HOST=0.0.0.0

# ── Email (optional) ───────────────────────────────────────────────────────────
# Required for: forgot password, email-based user invites.
# Leave blank to disable email features.
APP_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Development only ───────────────────────────────────────────────────────────
# Leave empty in production. In development, set to http://localhost:5173
FRONTEND_URL=
